{
  "version": "intent-planner-v1",
  "purpose": "Deterministic planning harness that maps simple user intents into study-plan-v1 drafts without AI calls.",
  "outputFields": [
    "version",
    "intent",
    "templateId",
    "templateLabel",
    "confidence",
    "plan",
    "preview",
    "diagnostics"
  ],
  "diagnosticCodes": [
    "intent.benchmark_defaulted",
    "intent.date_defaulted",
    "intent.empty",
    "intent.subject_defaulted",
    "intent.template_defaulted"
  ],
  "confidenceValues": [
    "draft",
    "needs-review",
    "blocked"
  ],
  "hardLimits": [
    "Planner output is only a draft.",
    "StudyPlan validation remains authoritative.",
    "Route handoff still requires the confirmation preview.",
    "Unknown subjects are defaulted or surfaced as diagnostics; they are not provider-verified here."
  ],
